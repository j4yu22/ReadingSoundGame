# Copy to .env if you want the new src/api backend to use different values.
# It also reads ../../test/arthur/.env so you do not have to duplicate keys locally.

AZURE_SPEECH_KEY=replace-with-your-key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=en-US-GuyNeural
AZURE_SPEECH_FORMAT=audio-24khz-48kbitrate-mono-mp3
