# Local Docker Compose settings. Copy this file to .env and fill in real values.
# Do not commit the real .env file.

AZURE_SPEECH_KEY=replace-with-your-key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=en-US-AvaNeural
AZURE_SPEECH_FORMAT=audio-24khz-48kbitrate-mono-mp3
AZURE_STT_LANGUAGE=en-US
AZURE_STT_CORRECTNESS_THRESHOLD=65

# For local Docker testing you can use :80 and set HTTP_PORT=8080.
# For deployed microphone support, use a real domain here so Caddy can issue HTTPS.
SITE_ADDRESS=:80
ACME_EMAIL=
HTTP_PORT=8080
HTTPS_PORT=8443
